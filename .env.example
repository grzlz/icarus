# Copy to .env and fill in. .env is gitignored.

# OpenAI API key for the /taller image generator (GPT Image 1.5 edits API).
# Get one at https://platform.openai.com/api-keys (requires a funded account).
OPENAI_API_KEY=

# Optional gate for /taller. If set, the tool requires this password before it
# will spend API credits. Leave blank to disable the gate.
TALLER_PASSWORD=
